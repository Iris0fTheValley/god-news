# Copy to .env. Never commit real credentials.
GOD_NEWS_APP_NAME=god-news
GOD_NEWS_ENVIRONMENT=development
GOD_NEWS_LOG_LEVEL=INFO
GOD_NEWS_API_HOST=127.0.0.1
GOD_NEWS_API_PORT=8000
GOD_NEWS_READINESS_TIMEOUT_SECONDS=10
GOD_NEWS_DATABASE_URL=sqlite+aiosqlite:///./data/god_news.db
GOD_NEWS_DATABASE_AUTO_CREATE=true
GOD_NEWS_DATABASE_BUSY_TIMEOUT_MS=5000
GOD_NEWS_OUTPUT_DIR=./outputs
GOD_NEWS_UPLOADED_VIDEO_DIR=./uploads/videos
GOD_NEWS_VIDEO_BGM_DIRECTORY=./assets/bgm
GOD_NEWS_VIDEO_CANDIDATE_SCAN_LIMIT=1000

# Retention is path-scoped to the two roots above. The scheduler is off by
# default and defaults to dry-run even when enabled; manual cleanup also
# defaults to dry-run at the API boundary.
GOD_NEWS_RETENTION_MEDIA_DAYS=7
GOD_NEWS_RETENTION_UPLOADED_MP4_DAYS=3
GOD_NEWS_RETENTION_MEDIA_EXTENSIONS=[".wav",".mp3",".flac",".aac",".ogg",".m4a",".png",".jpg",".jpeg",".webp"]
GOD_NEWS_OPERATIONS_HISTORY_LIMIT=100
GOD_NEWS_OPERATIONS_SCHEDULER_ENABLED=false
GOD_NEWS_OPERATIONS_SCHEDULER_INTERVAL_SECONDS=86400
GOD_NEWS_OPERATIONS_SCHEDULER_POLL_SECONDS=5
GOD_NEWS_OPERATIONS_SCHEDULER_RETENTION_DRY_RUN=true

# DeepSeek is the default provider. The key shown in chat must be revoked;
# put a newly-created key here only in your local .env.
GOD_NEWS_LLM_PROVIDER=deepseek
GOD_NEWS_DEEPSEEK_API_KEY=
GOD_NEWS_DEEPSEEK_BASE_URL=https://api.deepseek.com
GOD_NEWS_DEEPSEEK_MODEL=deepseek-v4-flash
GOD_NEWS_LLM_THINKING_ENABLED=false
GOD_NEWS_LLM_TIMEOUT_SECONDS=120
GOD_NEWS_LLM_MAX_RETRIES=2
GOD_NEWS_LLM_VALIDATION_RETRIES=1
GOD_NEWS_LLM_MAX_OUTPUT_TOKENS=4096
GOD_NEWS_LLM_TEMPERATURE=0.1
GOD_NEWS_MAX_SOURCE_CHARACTERS=60000

# Optional LM Studio provider.
GOD_NEWS_LOCAL_LLM_ENABLED=false
GOD_NEWS_LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
GOD_NEWS_LOCAL_LLM_API_KEY=lm-studio
GOD_NEWS_LOCAL_LLM_MODEL=Qwen3.5-35B-A3B-heretic-v2-Q4_K_M

# Embedded ChromaDB memory. The default embedding model runs locally; its model
# files are downloaded once by Chroma on first semantic write/query and then cached.
GOD_NEWS_MEMORY_PROVIDER=chromadb
GOD_NEWS_MEMORY_RECALL_FAIL_OPEN=true
GOD_NEWS_MEMORY_RECALL_LIMIT=5
GOD_NEWS_MEMORY_MAX_CONTEXT_CHARACTERS=4000
GOD_NEWS_MEMORY_CHROMA_PERSIST_DIRECTORY=./data/chroma
GOD_NEWS_MEMORY_CHROMA_COLLECTION=god-news-memory-v1
GOD_NEWS_MEMORY_CHROMA_EMBEDDING_FUNCTION=default
GOD_NEWS_MEMORY_CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Fetch chain: Jina -> DrissionPage -> Scrapy + Trafilatura.
GOD_NEWS_JINA_API_KEY=
GOD_NEWS_JINA_BASE_URL=https://r.jina.ai
GOD_NEWS_JINA_PAGE_TIMEOUT_SECONDS=20
GOD_NEWS_FETCH_CONNECT_TIMEOUT_SECONDS=10
GOD_NEWS_FETCH_READ_TIMEOUT_SECONDS=45
GOD_NEWS_FETCH_MAX_CONNECTIONS=20
GOD_NEWS_FETCH_MAX_KEEPALIVE_CONNECTIONS=10
GOD_NEWS_FETCH_MAX_RESPONSE_BYTES=8388608
GOD_NEWS_FETCH_MIN_CONTENT_CHARACTERS=200
GOD_NEWS_ALLOW_PRIVATE_SOURCE_URLS=false
GOD_NEWS_ALLOWED_SOURCE_PORTS=[80,443]
GOD_NEWS_ENABLE_DRISSION_FETCHER=true
GOD_NEWS_DRISSION_TIMEOUT_SECONDS=35
GOD_NEWS_DRISSION_BASE_TIMEOUT_SECONDS=10
GOD_NEWS_DRISSION_SCRIPT_TIMEOUT_SECONDS=10
GOD_NEWS_DRISSION_QUIT_TIMEOUT_SECONDS=5
GOD_NEWS_DRISSION_MAX_CONCURRENCY=1
GOD_NEWS_DRISSION_WORKER_MODULE=god_news.workers.drission_fetch
GOD_NEWS_BROWSER_EGRESS_ISOLATED=false
GOD_NEWS_ENABLE_SCRAPY_FETCHER=true
GOD_NEWS_SCRAPY_TIMEOUT_SECONDS=60
GOD_NEWS_SCRAPY_DOWNLOAD_TIMEOUT_SECONDS=20
GOD_NEWS_SCRAPY_REDIRECT_MAX_TIMES=3
GOD_NEWS_SCRAPY_RETRY_TIMES=1
GOD_NEWS_SCRAPY_DEPTH_LIMIT=1
GOD_NEWS_SCRAPY_CLOSE_PAGE_COUNT=3
GOD_NEWS_SCRAPY_USER_AGENT="god-news/0.1 (+content research pipeline)"
GOD_NEWS_SCRAPY_WORKER_MODULE=god_news.workers.scrapy_fetch

# Fixed-source adapter policy. Live content access is disabled unless the
# operator explicitly records the required credentials/authorization here.
# Health probes use HEAD only and are disabled by default.
GOD_NEWS_SOURCE_HEALTH_NETWORK_PROBES_ENABLED=false
GOD_NEWS_SOURCE_RUN_MAX_PENDING=8
GOD_NEWS_SOURCE_DAZHONG_ENABLED=true
GOD_NEWS_SOURCE_DAZHONG_ENDPOINT=https://m.dzplus.dzng.com/
# Set true only after the operator has confirmed this public-page collection use.
GOD_NEWS_SOURCE_DAZHONG_PUBLIC_PAGE_USE_AUTHORIZED=false
GOD_NEWS_SOURCE_DAZHONG_COLLECTION_LIMIT=10
GOD_NEWS_SOURCE_DAZHONG_ALLOWED_HOST_SUFFIXES=["dzng.com"]
GOD_NEWS_SOURCE_REDDIT_ENABLED=true
GOD_NEWS_SOURCE_REDDIT_ENDPOINT=https://oauth.reddit.com/
GOD_NEWS_SOURCE_REDDIT_TOKEN_ENDPOINT=https://www.reddit.com/api/v1/access_token
GOD_NEWS_SOURCE_REDDIT_CLIENT_ID=
GOD_NEWS_SOURCE_REDDIT_CLIENT_SECRET=
# Required format example: windows:god-news:v0.1 (by /u/operator_name)
GOD_NEWS_SOURCE_REDDIT_USER_AGENT=
# Credentials alone are insufficient. Set true only after the approved Data API
# use explicitly covers downstream LLM processing and short-video production.
GOD_NEWS_SOURCE_REDDIT_API_USE_AUTHORIZED=false
GOD_NEWS_SOURCE_REDDIT_SUBREDDIT=HumansBeingBros
GOD_NEWS_SOURCE_REDDIT_COLLECTION_LIMIT=25
GOD_NEWS_SOURCE_GUARDIAN_ENABLED=true
GOD_NEWS_SOURCE_GUARDIAN_ENDPOINT=https://content.guardianapis.com/
GOD_NEWS_SOURCE_GUARDIAN_API_KEY=
# Guardian AI/derived-product use may require a Commercial agreement. A key by
# itself does not authorize this pipeline.
GOD_NEWS_SOURCE_GUARDIAN_AI_USE_AUTHORIZED=false
GOD_NEWS_SOURCE_GUARDIAN_QUERY=kindness
GOD_NEWS_SOURCE_GUARDIAN_SECTION=
GOD_NEWS_SOURCE_GUARDIAN_COLLECTION_LIMIT=25
GOD_NEWS_SOURCE_PIKABU_ENABLED=true
GOD_NEWS_SOURCE_PIKABU_ENDPOINT=https://pikabu.ru/tag/%D0%94%D0%BE%D0%B1%D1%80%D0%BE%D1%82%D0%B0
# The collector stops the entire run on CAPTCHA/bot verification and never
# attempts to bypass it.
GOD_NEWS_SOURCE_PIKABU_PUBLIC_PAGE_USE_AUTHORIZED=false
GOD_NEWS_SOURCE_PIKABU_COLLECTION_LIMIT=10
GOD_NEWS_SOURCE_PIKABU_ALLOWED_HOST_SUFFIXES=["pikabu.ru"]

# GPT-SoVITS v2Pro: one isolated API process per story.
GOD_NEWS_TTS_ENABLED=true
GOD_NEWS_GPT_SOVITS_ROOT=J:/AI friend/GPT-SoVITS-v2pro-20250604
GOD_NEWS_GPT_SOVITS_PYTHON=J:/AI friend/GPT-SoVITS-v2pro-20250604/runtime/python.exe
GOD_NEWS_GPT_SOVITS_CONFIG=J:/AI friend/GPT-SoVITS-v2pro-20250604/GPT_SoVITS/configs/tts_infer.yaml
GOD_NEWS_TTS_REFERENCE_AUDIO=J:/AI friend/GPT-SoVITS-v2pro-20250604/show/参考音频.wav
GOD_NEWS_TTS_REFERENCE_TEXT_FILE=J:/AI friend/GPT-SoVITS-v2pro-20250604/show/参考文本.txt
GOD_NEWS_TTS_PROMPT_LANGUAGE=en
GOD_NEWS_TTS_TEXT_LANGUAGE=auto
GOD_NEWS_TTS_DEFAULT_SPEAKER_ID=narrator
# v2Pro uses the shipped v2Pro base model. To select the trained Neuro v2 voice,
# set profile=v2 and set both explicit weights paths; never mix a v2 GPT weight
# with a v2Pro SoVITS weight.
GOD_NEWS_TTS_MODEL_PROFILE=v2Pro
GOD_NEWS_TTS_GPT_WEIGHTS=
GOD_NEWS_TTS_SOVITS_WEIGHTS=
GOD_NEWS_TTS_DEVICE=cuda
GOD_NEWS_TTS_USE_HALF_PRECISION=true
GOD_NEWS_TTS_STARTUP_TIMEOUT_SECONDS=180
GOD_NEWS_TTS_REQUEST_TIMEOUT_SECONDS=300
GOD_NEWS_TTS_SHUTDOWN_TIMEOUT_SECONDS=15
GOD_NEWS_TTS_PROBE_TIMEOUT_SECONDS=2
GOD_NEWS_TTS_STARTUP_POLL_INTERVAL_SECONDS=0.5
GOD_NEWS_TTS_FORCE_SHUTDOWN_WAIT_SECONDS=0.5
GOD_NEWS_TTS_PROCESS_KILL_GRACE_SECONDS=5
GOD_NEWS_TTS_DRAIN_TIMEOUT_SECONDS=5
GOD_NEWS_TTS_MAX_CONCURRENCY=1
GOD_NEWS_TTS_MAX_AUDIO_BYTES=209715200
GOD_NEWS_TTS_SEED=42
GOD_NEWS_TTS_TOP_K=5
GOD_NEWS_TTS_TOP_P=1.0
GOD_NEWS_TTS_TEMPERATURE=1.0
GOD_NEWS_TTS_TEXT_SPLIT_METHOD=cut5
GOD_NEWS_TTS_BATCH_SIZE=1
GOD_NEWS_TTS_BATCH_THRESHOLD=0.75
GOD_NEWS_TTS_FRAGMENT_INTERVAL=0.3
GOD_NEWS_TTS_REPETITION_PENALTY=1.35
GOD_NEWS_TTS_PARALLEL_INFER=true
